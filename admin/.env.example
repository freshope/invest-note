# FastAPI 서버 주소 (정적 export 환경에서는 필수). /admin/* 을 bare 로 호출한다.
# 로컬 dev 기본 포트: api=3108 (Makefile api_PORT)
NEXT_PUBLIC_API_BASE_URL=http://localhost:3108

# --- Supabase Auth (추후 제거 대상) ---
# app 과 동일 Supabase 프로젝트를 재사용한다. 이 그룹은 lib/auth/ 단일 모듈에서만 소비된다.
# 탈-Supabase 시 이 env 그룹과 lib/auth/ 만 교체하면 된다.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
