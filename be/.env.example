# 로컬 개발 기본값 — Supabase CLI 로컬 스택 (`supabase start`).
# 포트 충돌 회피를 위해 invest-note 는 54xxx 대신 64xxx 대역 사용 (supabase/config.toml 참조).
SUPABASE_URL=http://127.0.0.1:64321
CORS_ORIGINS=["http://localhost:3000","https://localhost:3000","capacitor://localhost","https://localhost"]

# 로컬 Postgres 직접 연결.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:64322/postgres

# Supabase secret 키 — 계정 탈퇴(DELETE /api/me) 시 auth.users 삭제에 사용.
# `supabase status` 의 `Secret`(sb_secret_...) 값. 운영 환경(클라우드)에서는 반드시 주입.
SUPABASE_SECRET_KEY=

# 강제 업데이트 모달의 "지금 업데이트" 버튼이 여는 스토어 URL. 비워두면 버튼이 동작하지 않는다.
# MIN_SUPPORTED_VERSION 을 올리기 전에 먼저 설정할 것.
STORE_URL_IOS=https://apps.apple.com/kr/app/id6769310576
STORE_URL_ANDROID=https://play.google.com/store/apps/details?id=app.pixelwave.investnote

# 강제 업데이트 최소 지원 버전(versionName). 비워두면 강제하지 않는다(no-force).
# 양쪽 스토어에 새 버전이 모두 올라간 뒤에만 값을 올린다. 예: 1.0.16
MIN_SUPPORTED_VERSION=

# 종목 마스터 적재(scripts/seed_stocks.py)용 공공데이터포털 인증키. 런타임 미사용 — batch 전용.
# 비워두면 data.go.kr coverage/soft-delete pass 를 건너뛴다(검색/import 가 빈 결과로 degraded).
# 발급: data.go.kr → "금융위원회_KRX상장종목정보"(data/15094775) 활용신청(자동승인, 개발계정 1만콜/일).
# ⚠️ httpx params= 로 전달하므로 반드시 "Decoding(원본)" 키를 넣을 것 — Encoding 키는 이중 인코딩으로 실패.
DATA_GO_KR_API_KEY=

# 종목 검색(GET /stocks/search) provider. "naver" | "db". 미설정 시 naver.
# naver: Naver 자동완성 라이브 호출. db: 로컬 stocks 마스터(data.go.kr seed) 조회.
# data.go.kr 적재 안정성 모니터링 후 "db" 로 복귀.
STOCK_SEARCH_PROVIDER=naver

# 시세(GET /stocks/quote 등) 공급자 우선순위 체인. 콤마 구분, 앞 항목부터 시도.
# 등록 공급자: "naver"(realtime→basic), "yahoo"(.KS/.KQ). 미설정 시 naver,yahoo.
QUOTE_PROVIDERS=naver,yahoo

# 종목 마스터 seed 소스 체인. 콤마 구분, 순서=우선순위. 첫 항목이 authority(종목명 overwrite).
# 등록 소스: "data_go_kr", "stock_prices", "securities". 미설정 시 아래 기본 순서.
STOCK_SEED_SOURCES=data_go_kr,stock_prices,securities

# 일별 종가(자산 추이) primary 공급자. 등록: "data_go_kr". 미설정 시 data_go_kr.
DAILY_PRICE_PROVIDER=data_go_kr

# 일별 종가 T+1 tail-gap 보충 공급자. 등록: "naver". "none" 또는 빈 값이면 보충 비활성.
DAILY_PRICE_GAP_PROVIDER=naver

# NPS 보유내역 seed 공급자. 등록: "odcloud". 미설정 시 odcloud.
NPS_PROVIDER=odcloud

# 관리자 적재 트리거(POST /admin/seed/stocks) 인증 토큰. X-Admin-Token 헤더로 전달.
# 비워두면 admin 엔드포인트는 항상 거부(미설정=차단). 외부 cron/스케줄러가 이 값을 헤더로 보낸다.
ADMIN_TOKEN=

# 클라우드 전환 시 (참고) — Supabase Supavisor session pooler (port 5432, IPv4 지원):
#   SUPABASE_URL=https://<ref>.supabase.co
#   DATABASE_URL=postgresql://postgres.<project_ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
