# 로컬 Supabase Auth — OAuth provider credentials.
# 사용법:
#   1. cp supabase/.env.example supabase/.env
#   2. 아래 값을 채운다 (Google/Kakao Console 또는 클라우드 Supabase Dashboard 와 동일 값 재사용 가능)
#   3. Google Cloud Console / Kakao Developers 의 redirect URI 에 다음을 추가한다:
#        http://127.0.0.1:64321/auth/v1/callback
#   4. supabase stop && supabase start

# Google OAuth (Google Cloud Console → APIs & Services → Credentials)
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=

# Kakao OAuth (Kakao Developers → 내 애플리케이션 → 카카오 로그인)
SUPABASE_AUTH_EXTERNAL_KAKAO_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_KAKAO_SECRET=
