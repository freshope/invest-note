# 릴리즈 전용 환경변수 (OTA 발행 스크립트 scripts/publish-ota.mjs).
# 실제 값은 루트 gitignored .env 에만 둔다. fe public env(NEXT_PUBLIC_*,
# .env.development.local)·.env.local 에는 절대 넣지 않는다(번들 누출 방지, 결정 4).
# BE 는 R2 자격증명이 불필요하다(manifest public-read GET).

# Cloudflare R2 (S3 호환) write 자격증명 — 릴리즈 스크립트만 사용
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# 번들 zip 의 public/CDN base URL. manifest 의 url = <base>/bundles/<version>.zip
R2_PUBLIC_BASE_URL=

# (선택) manifest 객체 키. 미지정 시 manifest/latest.json.
# BE 의 live_update_manifest_url 이 가리키는 경로와 정합해야 한다.
R2_MANIFEST_KEY=
