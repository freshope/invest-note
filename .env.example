# 릴리즈 전용 환경변수 (OTA 발행 스크립트 scripts/publish-ota.mjs).
# 실제 값은 루트 gitignored .env 에만 둔다. fe public env(NEXT_PUBLIC_*,
# .env.development.local)·.env.local 에는 절대 넣지 않는다(번들 누출 방지, 결정 4).
# BE 는 R2 자격증명이 불필요하다(manifest public-read GET).

# Cloudflare R2 (S3 호환) write 자격증명 — 릴리즈 스크립트만 사용
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# 번들 zip 의 public/CDN base URL. manifest 의 url = <base>/bundles/<version>.zip
R2_PUBLIC_BASE_URL=

# (선택) manifest 객체 키. 미지정 시 manifest/latest.json.
# BE 의 live_update_manifest_url 이 가리키는 경로와 정합해야 한다.
R2_MANIFEST_KEY=

# OTA 번들이 요구하는 최소 네이티브 버전 = "현재 스토어에 라이브로 승인된 바이너리의
# 마케팅 버전"(레포 fe/package.json version 아님 — OTA web-only 릴리즈마다 레포 버전이
# 앞서가 스토어 바이너리와 어긋난다). publish-ota 가 manifest.required_native_version 으로
# 사용한다. 미설정 시 발행 중단(레포 version 으로 폴백하지 않음). --required-native 인자로 덮어쓸 수 있다.
# ★ 네이티브를 실제 스토어에 제출·승인할 때만 이 값을 갱신한다(OTA web-only 릴리즈에서는 건드리지 않음).
OTA_REQUIRED_NATIVE=
