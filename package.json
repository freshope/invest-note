{
  "name": "invest-note",
  "private": true,
  "scripts": {
    "dev": "pnpm -C app dev",
    "restart:be": "cd api && make restart",
    "restart:fe": "sh -c 'kill $(lsof -ti tcp:3000) 2>/dev/null || true; pnpm -C app dev'",
    "build": "pnpm -C app build",
    "lint": "pnpm -C app lint",
    "test": "pnpm -C app test",
    "tsc": "pnpm -C app exec tsc --noEmit",
    "device:ios": "pnpm -C app device:ios",
    "device:android": "pnpm -C app device:android",
    "bundle:android": "sh app/scripts/bundle-android.sh",
    "version:sync": "node scripts/version.mjs sync",
    "version:check": "node scripts/version.mjs check",
    "version:set": "node scripts/version.mjs set",
    "version:bump": "node scripts/version.mjs bump"
  }
}
