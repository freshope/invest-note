{
  "name": "invest-note",
  "private": true,
  "packageManager": "pnpm@10.17.1",
  "scripts": {
    "dev": "pnpm -C fe dev",
    "restart:be": "cd be && make restart",
    "restart:fe": "sh -c 'kill $(lsof -ti tcp:3000) 2>/dev/null || true; pnpm -C fe dev'",
    "build": "pnpm -C fe build",
    "lint": "pnpm -C fe lint",
    "test": "pnpm -C fe test",
    "tsc": "pnpm -C fe exec tsc --noEmit",
    "device:ios": "pnpm -C fe device:ios",
    "device:android": "pnpm -C fe device:android",
    "bundle:android": "sh fe/scripts/bundle-android.sh",
    "version:sync": "node scripts/version.mjs sync",
    "version:check": "node scripts/version.mjs check",
    "version:set": "node scripts/version.mjs set",
    "version:bump": "node scripts/version.mjs bump"
  }
}
