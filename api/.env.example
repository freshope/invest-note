CORS_ORIGINS=["http://localhost:3100","http://127.0.0.1:3100","http://localhost:3101","http://127.0.0.1:3101","capacitor://localhost","https://localhost"]

# 로컬 Postgres 직접 연결.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:64322/postgres

# OIDC 토큰 검증 — IdP 교체 대비 seam(현재 IdP=Supabase).
# OIDC_ISSUER: 빈 값이면 iss 검증을 스킵(fail-safe). 실제 Supabase iss 는
#   "<SUPABASE_URL>/auth/v1" — 정확히 대조 후 prod 에서만 활성화. 잘못 켜면 전체 인증 붕괴.
OIDC_ISSUER=
# OIDC_AUDIENCE: 토큰 aud 기대값. 기본 "authenticated"(Supabase 컨벤션).
#   ⚠️ 비워서(present-but-empty) 두지 말 것 — 코드가 AUTH_ROLE 로 정규화하지만,
#   다른 IdP 로 aud 가 바뀔 때만 주석 해제해 명시 설정한다.
# OIDC_AUDIENCE=authenticated

# ──────────────────────────────────────────────────────────────────────────
# BE 토큰-브로커(탈-Supabase Auth). cutover 완료 — 2c 로 Supabase flow 물리 제거됨.
# 운영은 BE flow 단일 경로이므로 아래 서명키 등은 인증 필수 값(비우면 인증 dormant).
# ──────────────────────────────────────────────────────────────────────────

# 네이티브 BE flow 서버 플래그. 운영은 항상 true(BE flow 단일). app-config 의
# beAuthEnabled 로 앱에 노출. FE 에 supabase-js 가 없어 false 면 네이티브 인증 경로 없음.
BE_AUTH_ENABLED=true

# BE 발급 토큰 서명(ES256, EC P-256). SIGNING_KEY 가 있어야 BE 토큰 발급/검증 활성(없으면 dormant·빈 JWKS).
# 키 생성: openssl ecparam -name prime256v1 -genkey -noout -out be_token_es256_priv.pem
#   → PEM 파일 전체를 값으로(멀티라인. literal \n 금지 — 실제 개행).
BE_TOKEN_SIGNING_KEY=
# JWKS 항목과 토큰 header.kid 를 잇는 자유 안정 문자열(키 회전 시 변경). 예: be-2026-06
BE_TOKEN_KID=
# BE 토큰 iss — Supabase iss 와 충돌 없는 고유 안정 문자열. 예: https://<API_HOST>/be-auth
BE_TOKEN_ISSUER=
# BE 토큰 aud — ⚠️ Supabase "authenticated" 와 반드시 다르게(per-issuer aud 격리).
#   SIGNING_KEY 가 있는데 비우면 기동 실패(fail-fast). 예: invest-note-app
BE_TOKEN_AUDIENCE=

# OAuth 중개 provider 자격증명. IdP redirect_uri = {BE_OAUTH_REDIRECT_BASE}/auth/callback.
# Google: OIDC client_id/secret 한 쌍.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Kakao: REST API key(=client_id) + client secret(/v2/user/me userinfo).
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
# Apple: 기존 Supabase Service ID 를 client_id 로 재사용(sub 보존). client secret 은
#   team_id/key_id/private_key(.p8 전체, 멀티라인)로 BE 가 동적 서명한다.
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# BE 공개 호스트(https://api...). IdP redirect_uri 베이스 + BE 자기-JWKS 호스트 출처.
BE_OAUTH_REDIRECT_BASE=

# (선택, 기본값 있음) callback 이 일회용 code 를 앱으로 돌려보내는 딥링크 스킴.
# 기본=app.pixelwave.investnote://auth/callback (기존 바이너리 등록 스킴 재사용).
# BE_DEEPLINK_SCHEME=app.pixelwave.investnote://auth/callback
# 어드민 웹 패널(client=admin)용 callback URL(BE→client 2차 hop). 빈 값이면 client=admin 503.
# 예: https://<admin-domain>/auth/callback/
BE_ADMIN_REDIRECT_URL=
# 개발 편의용 웹 BE flow(client=web)용 callback URL. 빈 값이면 client=web 503(운영 dormant 의도).
# 로컬 예: http://localhost:3100/auth/callback/ (app web dev 서버)
BE_APP_WEB_REDIRECT_URL=
# (선택) refresh token 수명(초, 기본 30d) / 일회용 code(기본 60s) / state·PKCE(기본 600s).
# BE_REFRESH_TOKEN_TTL=2592000
# OAUTH_CODE_TTL=60
# OAUTH_STATE_TTL=600

# 강제 업데이트 모달의 "지금 업데이트" 버튼이 여는 스토어 URL. 비워두면 버튼이 동작하지 않는다.
# MIN_SUPPORTED_VERSION 을 올리기 전에 먼저 설정할 것.
STORE_URL_IOS=https://apps.apple.com/kr/app/id6769310576
STORE_URL_ANDROID=https://play.google.com/store/apps/details?id=app.pixelwave.investnote

# 강제 업데이트 최소 지원 버전(versionName). 비워두면 강제하지 않는다(no-force).
# 양쪽 스토어에 새 버전이 모두 올라간 뒤에만 값을 올린다. 예: 1.0.16
MIN_SUPPORTED_VERSION=

# Capacitor OTA 라이브 업데이트: R2 발행 매니페스트 JSON 의 public 절대 URL.
# = <R2_PUBLIC_BASE_URL>/<R2_MANIFEST_KEY> (릴리즈 .env 와 경로 일치 필수).
# POST /live-update/manifest 가 이 URL 을 GET 해 발행 번들을 판단한다.
# 비워두면 fail-open(no-update) — 앱은 정상, OTA 만 비활성. 예:
#   https://invest-note-ota.pixelwave.app/manifest/latest.json
LIVE_UPDATE_MANIFEST_URL=

# ── Cloudflare R2 (거래내역서 제보 첨부 스토리지) ──────────────────────────────
# 4개가 모두 있어야 활성(r2_enabled). 하나라도 비면 dormant → presign/submit/다운로드 503
# (앱 기동·기존 일괄등록은 무회귀). OTA 와 같은 R2 계정이되 버킷은 분리(비공개 전용).
#
# 설정(Cloudflare 대시보드):
#  1) 비공개 버킷 `invest-note-uploads` 생성 (Public access OFF)
#  2) R2 API 토큰 발급 — 권한 "Object Read & Write" (등록 시 temp→정식 copy 에 write 필요)
#  3) 버킷 CORS (앱이 temp 로 browser PUT): AllowedOrigins=http://127.0.0.1:3100,
#     http://localhost:3100, capacitor://localhost(iOS), https://localhost(Android)
#     / AllowedMethods=PUT / AllowedHeaders=content-type
#     ⚠️ dev 서버는 127.0.0.1 로 바인딩 — 브라우저는 127.0.0.1≠localhost 이므로 둘 다 필요.
#  4) Lifecycle: prefix `temp/` 1일 후 자동 삭제 (미등록 업로드 청소)
#
# 저장 경로: 업로드=temp/{user_id}/{uuid}.{ext} → 등록 시 broker_statement/{user_id}/{uuid}.{ext}
R2_ENDPOINT_URL=          # https://<ACCOUNT_ID>.r2.cloudflarestorage.com (버킷명 미포함)
R2_BUCKET=                # invest-note-uploads
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# 선택 — 기본값 사용 시 생략 가능
# R2_REGION=auto
# R2_PRESIGN_EXPIRY=900   # presigned URL 유효시간(초)

# 종목 마스터 적재(scripts/seed_stocks.py)용 공공데이터포털 인증키. 런타임 미사용 — batch 전용.
# 비워두면 data.go.kr coverage/soft-delete pass 를 건너뛴다(검색/import 가 빈 결과로 degraded).
# 발급: data.go.kr → "금융위원회_KRX상장종목정보"(data/15094775) 활용신청(자동승인, 개발계정 1만콜/일).
# ⚠️ httpx params= 로 전달하므로 반드시 "Decoding(원본)" 키를 넣을 것 — Encoding 키는 이중 인코딩으로 실패.
DATA_GO_KR_API_KEY=

# KIS Open API(한국투자증권) 앱키/시크릿 — kis 공급자(시세/일별 종가) 사용 시 필요.
# 발급: KIS Developers(apiportal.koreainvestment.com) 가입 → 앱 등록(36자 키 + 180자 시크릿).
# 비워두면 kis 공급자는 호출 시 토큰 발급 실패 → 체인의 다음 공급자로 fallback.
# 종목마스터(STOCK_SEED_SOURCES=kis)·교차검증(CROSSVALIDATE_PROVIDER=kis)은 공개 CDN 파일이라 키 불필요.
KIS_APP_KEY=
KIS_APP_SECRET=

# KIS 환경. "real"(실전) | "mock"(모의투자) — API 도메인 분기. 미설정 시 real.
KIS_ENV=real

# OpenFIGI ISIN→ticker 해소(토스 해외 import) API 키 — 옵션.
# 비워두면 무키 경로(25req/분·10건/요청)로 동작한다. 키가 있으면 25req/6초·100건/요청.
# 발급: openfigi.com/api → 무료 API key(즉시 발급). 토스 USD 거래 ISIN 매칭에만 사용.
OPENFIGI_API_KEY=

# 종목 검색(GET /stocks/search) provider. "naver" | "db". 미설정 시 naver.
# naver: Naver 자동완성 라이브 호출. db: 로컬 stocks 마스터(data.go.kr seed) 조회.
# data.go.kr 적재 안정성 모니터링 후 "db" 로 복귀.
STOCK_SEARCH_PROVIDER=naver

# 시세(GET /stocks/quote 등) 공급자 우선순위 체인. 콤마 구분, 앞 항목부터 시도.
# 등록 공급자: "naver"(realtime→basic), "yahoo"(.KS/.KQ), "kis"(현재가, 앱키 필요). 미설정 시 naver,yahoo.
QUOTE_PROVIDERS=naver,yahoo

# 해외(US) 시세 공급자 체인. 등록: "yahoo"(bare 티커). 미설정 시 yahoo.
US_QUOTE_PROVIDERS=yahoo

# 환율(FX, USD/KRW 등) 공급자 체인. 앞 항목부터 시도해 첫 성공값 사용.
# 등록: "yahoo"({quote}=X), "er_api"(open.er-api.com, 무인증 폴백). 미설정 시 yahoo,er_api.
FX_PROVIDERS=yahoo,er_api

# 종목 마스터 seed 소스 체인. 콤마 구분, 순서=우선순위. 첫 항목이 authority(종목명 overwrite).
# 등록 소스: "data_go_kr", "stock_prices", "securities", "kis"(종목마스터 파일, 키 불필요). 미설정 시 아래 기본 순서.
STOCK_SEED_SOURCES=data_go_kr,stock_prices,securities,kis

# 해외(US) 종목 마스터 seed 소스 체인. 등록: "nasdaqtrader"(공개 심볼 파일, 키 불필요). 미설정 시 nasdaqtrader.
US_STOCK_SEED_SOURCES=nasdaqtrader

# 일별 종가(자산 추이) primary 공급자. 등록: "data_go_kr", "kis"(앱키 필요). 미설정 시 data_go_kr.
DAILY_PRICE_PROVIDER=data_go_kr

# 해외(US) 일별 종가 primary 공급자. 등록: "yahoo"(chart v8 range). 미설정 시 yahoo. (US 는 T+1 gap 개념 없음)
US_DAILY_PRICE_PROVIDER=yahoo

# 일별 종가 T+1 tail-gap 보충 공급자. 등록: "naver", "kis"(T+0 반영, 앱키 필요).
# "none" 또는 빈 값이면 보충 비활성.
DAILY_PRICE_GAP_PROVIDER=naver

# 종목 교차검증(seed 5단계) 공급자. "naver"(종목별 자동완성 조회) | "kis"(종목마스터 파일 일괄 대조, 키 불필요).
# 미설정 시 naver.
CROSSVALIDATE_PROVIDER=naver

# NPS 보유내역 seed 공급자. 등록: "odcloud". 미설정 시 odcloud.
NPS_PROVIDER=odcloud

# 어드민 패널(admin/) 접근 허용 이메일 allowlist(콤마 구분). require_admin 게이트가
# Supabase JWT 의 email 클레임을 이 목록과 정확비교(대소문자 무시). 본인 구글 로그인 이메일로.
ADMIN_EMAILS=
