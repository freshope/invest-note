# Next.js 사이트 URL (메타데이터/OG 용도). 비워두면 기본 동작.
NEXT_PUBLIC_SITE_URL=

# FastAPI 백엔드 URL. 값이 있으면 브라우저 fetch + SSR 서버 컴포넌트 모두 해당 origin으로 전환됨.
# 로컬: http://localhost:8000  |  운영: Render/Railway URL
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Supabase — 로컬 개발 기본값 (`supabase start`, 포트 64321 대역).
# 키는 로컬 인스턴스마다 다르므로 `supabase status -o env` 로 확인.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:64321
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# 클라우드 전환 시 (참고):
#   NEXT_PUBLIC_SUPABASE_URL=https://<ref>.supabase.co
#   NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
#   SUPABASE_SECRET_KEY=sb_secret_...
