# Next.js 사이트 URL (메타데이터/OG 용도). 비워두면 기본 동작.
NEXT_PUBLIC_SITE_URL=

# FastAPI 백엔드 URL. 값이 있으면 브라우저 fetch + SSR 서버 컴포넌트 모두 해당 origin으로 전환됨.
# 로컬: http://localhost:8000  |  운영: Render/Railway URL
# 비워두면 브라우저는 Next.js /api/* 상대경로, SSR은 Supabase 직접 조회로 fallback.
NEXT_PUBLIC_API_BASE_URL=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
